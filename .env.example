# ============================================================
# DainikState - Environment Configuration
# ============================================================
# COPY: cp .env.example .env
# ============================================================

PORT=3000

# ============================================================
# ODYSEE CHANNEL (default: @DainikState:1)
# Set karna optional hai — agar channel claim ho gaya hai to set karo
# ============================================================
ODYSEE_CLAIM_ID=@DainikState:1

# Optional API key — get from https://odysee.com/settings/api
ODYSEE_API_KEY=
